APP_NAME=AI Center V3 Document Processing
API_PREFIX=
DATA_DIR=./data
SQLITE_PATH=./data/document_processing.sqlite3
QDRANT_PATH=./data/.qdrant
QDRANT_COLLECTION=doc_chunks
EMBEDDING_DIMENSIONS=1024
DEFAULT_TOP_K=5
LITELLM_API_KEY=your_api_key
LITELLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LITELLM_CHAT_MODEL=openai/qwen-plus
LITELLM_EMBEDDING_MODEL=openai/text-embedding-v4
LITELLM_TIMEOUT_SECONDS=60
LITELLM_CHAT_TEMPERATURE=0
LITELLM_CHAT_MAX_TOKENS=1024
LITELLM_EMBEDDING_BATCH_SIZE=10
DEBUG=false
